# ── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://cogwork:cogwork@localhost:5432/cogwork
ENCRYPTION_KEY=               # 32-byte base64 (openssl rand -base64 32)
AUTH_SECRET=                  # Auth.js secret (openssl rand -base64 32)
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Connector run mode: `fixture` (no third-party creds, default) or `live`.
COGWORK_CONNECTORS=fixture

# ── LLM (Builder + AI steps) ─────────────────────────────────────────────────
# The only external dependency that is live in Phases 0–2. Required for real
# workflow generation and AI steps. Generation tests use a mocked LLM in CI.
ANTHROPIC_API_KEY=
# optional provider swaps (Vercel AI SDK)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── OAuth apps (Phase 3 / go-live only — not needed for fixture mode) ─────────
# Redirect URI: APP_URL/api/connections/<provider>/callback
GOOGLE_CLIENT_ID=             # Gmail + Calendar (+ login)
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Tools (Phase 3 / go-live only) ───────────────────────────────────────────
APIFY_TOKEN=
