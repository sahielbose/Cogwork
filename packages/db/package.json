    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@cogwork/spec": "workspace:*",
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1"
  }
}
